{{! actor-template.hbs }}

<form class="{{cssClass}} my-system">
    <header class="sheet-header">
        <div class="title-area">
            <h1>Best Left Buried</h1>
            <div class="character-info">
                <input type="text" name="name" value="{{actor.name}}" placeholder="Name"/>
                <input type="text" name="system.archetype" value="{{system.archetype}}" placeholder="Archetype"/>
            </div>
        </div>
        <div class="xp-tracker">
            <h3>XP Tracker</h3>
            <div class="xp-counter">
                <div class="xp-controls">
                    <button type="button" class="xp-button decrease">
                        <i class="fas fa-minus"></i>
                    </button>
                    <input type="number" name="system.xp" value="{{system.xp}}" data-dtype="Number" min="0"/>
                    <button type="button" class="xp-button increase">
                        <i class="fas fa-plus"></i>
                    </button>
                </div>
            </div>
        </div>
    </header>

    <nav class="tabs" data-group="primary">
        <a class="item" data-tab="stats">Stats & Weapons</a>
        <a class="item" data-tab="equipment">Equipment & Treasure</a>
        <a class="item" data-tab="advancements">Advancements & Consequences</a>
    </nav>

    {{! Stats & Weapons Tab Content }}

    <section class="sheet-body">
        <div class="tab" data-group="primary" data-tab="stats">
            <h3>Stats & Weapons</h3>  

            {{! Stats }}           

            <div class="stats-grid">
         
            {{! Top row stats }}

          <div class="stat-box">
            <div class="stat-name">Brawn</div>
              <div class="ability-breakdown">
                <input type="number" name="system.brawn.base" value="{{system.brawn.base}}" data-dtype="Number"/>
                <span class="plus">+</span>
                <input type="number" name="system.brawn.bonus" value="{{system.brawn.bonus}}" data-dtype="Number"/>
                <span class="equals">=</span>
                <span class="total-score">{{system.brawnTotal}}</span>
              </div>
          </div>

            <div class="stat-box">
              <div class="stat-name">Wit</div>
                <div class="ability-breakdown">
                  <input type="number" name="system.wit.base" value="{{system.wit.base}}" data-dtype="Number"/>
                  <span class="plus">+</span>
                  <input type="number" name="system.wit.bonus" value="{{system.wit.bonus}}" data-dtype="Number"/>
                  <span class="equals">=</span>
                  <span class="total-score">{{system.witTotal}}</span>
               </div>
            </div>

            <div class="stat-box">
              <div class="stat-name">Will</div>
                <div class="ability-breakdown">
                  <input type="number" name="system.will.base" value="{{system.will.base}}" data-dtype="Number"/>
                  <span class="plus">+</span>
                  <input type="number" name="system.will.bonus" value="{{system.will.bonus}}" data-dtype="Number"/>
                  <span class="equals">=</span>
                  <span class="total-score">{{system.willTotal}}</span>
                </div>
            </div>
          
            <div class="stat-box">
              <div class="stat-name">Affluence</div>
                <div class="ability-breakdown">
                  <input type="number" name="system.affluence.base" value="{{system.affluence.base}}" data-dtype="Number"/>
                  <span class="plus">+</span>
                  <input type="number" name="system.affluence.bonus" value="{{system.affluence.bonus}}" data-dtype="Number"/>
                  <span class="equals">=</span>
                  <span class="total-score">{{system.affluenceTotal}}</span>
                </div>
                  <div class="optional-rule">Optional Rule</div>
          </div>

        {{! Bottom row }}

            <div class="stat-box">
              <div class="stat-name">Vigour</div>
                  <div class="ability-breakdown">
                  <input type="number" name="system.vigour.min" value="{{system.vigour.min}}" data-dtype="Number" title="Min"/>
                  <span class="plus">/</span>
                  <input type="number" name="system.vigour.max" value="{{system.vigour.max}}" data-dtype="Number" title="Max"/>
                </div>
            </div>

            <div class="stat-box">
              <div class="stat-name">Grip</div>
                  <div class="ability-breakdown">
                  <input type="number" name="system.grip.base" value="{{system.grip.base}}" data-dtype="Number"/>
                </div>
            </div>

            <div class="stat-box">
                <div class="stat-name">Armor</div>
                <div class="ability-breakdown">
                    <span class="armor-base">{{system.armor.base}}</span>
                    <span class="plus">+</span>
                    <span class="armor-bonus">{{system.armorBonus}}</span>
                    <span class="equals">=</span>
                    <span class="total-score">{{system.armorTotal}}</span>
                </div>
            </div>
          </div>
      

           {{!Weapons }}
           
          <div class="weapons-section">
                <h2>Weapons</h2>
                <div class="weapon-list">
                    <div class="weapon-headers">
                        <div>Name</div>
                        <div>Type</div>
                        <div>Range</div>
                        <div>Attack</div>
                        <div>Dmg</div>
                        <div>Init</div>
                        <div>Controls</div>
                    </div>
                    {{#each items.weapon as |item id|}}
                          <div class="weapon-row" data-item-id="{{item._id}}">
                            <div class="weapon-name">
                                <img src="{{item.img}}" width="24" height="24"/>
                                <span>{{item.name}}</span>
                            </div>
                            <div class="weapon-prop">{{getWeaponProperty item.system.type "label"}}</div>
                            <div class="weapon-prop">{{getWeaponProperty item.system.type "range"}}</div>
                            <div class="weapon-prop">{{getWeaponProperty item.system.type "attackStat"}}</div>
                            <div class="weapon-prop">{{getWeaponDamage item.system.type item.system.isTwoHanded}}</div>
                            <div class="weapon-prop">{{getWeaponProperty item.system.type "initiative"}}</div>
                            <div class="weapon-controls">
                                <button type="button" class="weapon-roll" data-weapon-id="{{item._id}}" title="Roll Attack">
                                    <i class="fas fa-dice-d6"></i>
                                </button>
                                <a class="item-control item-delete" title="Delete Item"><i class="fas fa-trash"></i></a>
                            </div>
                        </div>
                    {{/each}}
                </div>
            </div>
        </div>


        {{! Equipment Tab Content }}
        <div class="tab" data-group="primary" data-tab="equipment">
          <div class="equipment-grid">
            <div class="equipment-section">
              <h3>Armor</h3>
              <div class="armor-list">
                {{#each items.armor as |item id|}}
                    <div class="equipment-row" data-item-id="{{item._id}}">
                      <div class="equipment-name">
                        <img src="{{item.img}}" width="24" height="24"/>
                        <span>{{item.name}}</span>
                      </div>
                      <div class="equipment-type">{{getArmorType item.system.armorType}}</div>
                      <div class="equipment-equipped">
                        <input type="checkbox" class="equip-checkbox" data-item-id="{{item._id}}" {{checked item.system.equipped}}/>
                        <label>Equipped</label>
                      </div>
                      <div class="equipment-controls">
                        <a class="item-control item-edit" title="Edit Item"><i class="fas fa-edit"></i></a>
                        <a class="item-control item-delete" title="Delete Item"><i class="fas fa-trash"></i></a>
                      </div>
                    </div>
                {{/each}}
              </div>

              <h3>Shields</h3>
              <div class="shield-list">
                {{#each items.shield as |item id|}}
                    <div class="equipment-row" data-item-id="{{item._id}}">
                      <div class="equipment-name">
                        <img src="{{item.img}}" width="24" height="24"/>
                        <span>{{item.name}}</span>
                      </div>
                      <div class="equipment-type">Shield (+1)</div>
                      <div class="equipment-equipped">
                        <input type="checkbox" class="equip-checkbox" data-item-id="{{item._id}}" {{checked item.system.equipped}}/>
                        <label>Equipped</label>
                      </div>
                      <div class="equipment-controls">
                        <a class="item-control item-edit" title="Edit Item"><i class="fas fa-edit"></i></a>
                        <a class="item-control item-delete" title="Delete Item"><i class="fas fa-trash"></i></a>
                      </div>
                    </div>
                {{/each}}
              </div>
            </div>
            <div class="treasure-section">
              <h3>Treasure</h3>
              <!-- Treasure list here -->
            </div>
          </div>
        </div>

        {{! Advancements Tab Content }}
        <div class="tab" data-group="primary" data-tab="advancements">
          <div class="advancement-grid">
            <div class="advancement-section">
              <h3>Advancements</h3>
              <p><em>Character advancements and improvements will be displayed here.</em></p>
              <!-- Future: Add advancement items here when you create that item type -->
            </div>
            <div class="consequence-section">
              <h3>Consequences</h3>
              <p><em>Character consequences and injuries will be displayed here.</em></p>
              <!-- Future: Add consequence items here when you create that item type -->
            </div>
          </div>
        </div>
    </section>
</form>